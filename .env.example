# === CIRCLE DEVELOPER-CONTROLLED WALLETS ===
# Dapatkan dari Circle Console → Keys → Create API Key (format: PREFIX:ID:SECRET)
CIRCLE_API_KEY=TEST_API_KEY:your-api-key-id:your-api-key-secret

# Di-generate otomatis oleh scripts/generate-entity-secret.mjs
# ENTITY_SECRET=   (disimpan di .env.wallet, jangan di-commit)
# ENTITY_SECRET_CIPHERTEXT=   (disimpan di .env.wallet)

# === ARC TESTNET (Circle's L1 blockchain, USDC as gas) ===
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_WS_URL=wss://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app

# === USDC ON ARC ===
USDC_CONTRACT=0x3600000000000000000000000000000000000000
USDC_DECIMALS=6

# === AGENT WALLET (di-generate otomatis oleh scripts/setup-wallet.mjs) ===
CIRCLE_WALLET_SET_ID=
CIRCLE_WALLET_ID=
CIRCLE_WALLET_ADDRESS=

# === POLYMARKET SETTLEMENT ===
# Deposit address di Polymarket untuk kirim USDC saat placing bet
POLYMARKET_DEPOSIT_ADDRESS=

# === AI / LLM (untuk probability estimation) ===
# Groq — gratis, cepat, recommended untuk hackathon (https://console.groq.com)
GROQ_API_KEY=gsk_your-groq-api-key
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# === AGENT BEHAVIOR CONFIG ===
AGENT_NAME=AgoraPredictor-v1
MAX_BET_SIZE_USDC=10
MIN_CONFIDENCE_THRESHOLD=0.65
KELLY_FRACTION=0.25
POLL_INTERVAL_MS=60000
